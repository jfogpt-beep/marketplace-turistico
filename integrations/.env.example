# ============================================
# Marketplace Turístico — Variables de Entorno
# ============================================

# --- Cloudflare (Workers, D1, KV, R2, Queues, Vectorize, AI) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# D1 Database ID
D1_DATABASE_ID=

# KV Namespace IDs
KV_CACHE_NAMESPACE_ID=
KV_SESSIONS_NAMESPACE_ID=

# R2 Bucket
R2_BUCKET_NAME=marketplace-images
R2_PUBLIC_DOMAIN=

# Cloudflare Queues
QUEUE_EMAIL=email-queue
QUEUE_NOTIFICATION=notification-queue

# Cloudflare Vectorize (AI Search)
VECTORIZE_INDEX_NAME=listings-index

# Cloudflare AI (Workers AI)
AI_MODEL_NAME=@cf/baai/bge-large-en-v1.5

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (se crean con seed)
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
STRIPE_PRICE_HIGHLIGHT_7D=
STRIPE_PRICE_HIGHLIGHT_30D=

# --- Email Service (Resend / SendGrid / AWS SES) ---
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@tumarketplace.com
EMAIL_FROM_NAME=Marketplace Turístico

# --- Cloudflare Access / Zero Trust ---
ZERO_TRUST_TEAM_DOMAIN=
ZERO_TRUST_POLICY_AUD=

# --- App Config ---
APP_URL=https://tumarketplace.com
DASHBOARD_URL=https://tumarketplace.com/dashboard
ADMIN_URL=https://tumarketplace.com/dashboard/admin

# JWT
JWT_SECRET=super-secret-jwt-key-min-32-chars

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
